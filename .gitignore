```
# Laravel-specific ignores
vendor/
storage/
bootstrap/cache/

# Environment
.env
.env.local
.env.*

# Logs
*.log
storage/logs/*

# Compiled and build artifacts
*.php~
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Package manager caches
.npm/
.yarn/
.pnpm-store/

# PHP specific
.php_cs.cache
```